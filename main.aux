\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Ablation studies.} We compare three distillation variants in terms of (left) student lift success, (middle) teacher intervention rate $\beta $, and (right) unsafe episode rate, all plotted over training iterations. Shaded regions indicate variability across runs (mean $\pm $ std). Curves correspond to the three compared methods (blue: vanilla DAgger, yellow: vanilla SafeDAgger, green: our pipeline).}}{6}{figure.caption.3}\protected@file@percent }
\newlabel{fig:ablation}{{3}{6}{\textbf {Ablation studies.} We compare three distillation variants in terms of (left) student lift success, (middle) teacher intervention rate $\beta $, and (right) unsafe episode rate, all plotted over training iterations. Shaded regions indicate variability across runs (mean $\pm $ std). Curves correspond to the three compared methods (blue: vanilla DAgger, yellow: vanilla SafeDAgger, green: our pipeline)}{figure.caption.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {IV}{\ignorespaces Ablation performance across various objects (tested over 200 episodes). Each ablation reports lift success and average unsafe rate.}}{6}{table.caption.6}\protected@file@percent }
\newlabel{tab:ablation_studies}{{IV}{6}{Ablation performance across various objects (tested over 200 episodes). Each ablation reports lift success and average unsafe rate}{table.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Per-object failure-mode decomposition during online distillation ablations.} We illustrate four task-specific failure modes in simulation (harmful collision, object escape, palm flipped, and hand too far) and report the aggregate unsafe rate together with its per-mode breakdown over training iterations. Results are shown for two objects (\texttt  {windcart} and \texttt  {cow}); lower is better in all plots. Curves correspond to the three compared distillation variants (blue: vanilla DAgger\cite  {ross2011reduction}, yellow: vanilla SafeDAgger\cite  {zhang2016query}, green: our pipeline).}}{7}{figure.caption.7}\protected@file@percent }
\@writefile{brf}{\backcite{ross2011reduction}{{7}{4}{figure.caption.7}}}
\@writefile{brf}{\backcite{zhang2016query}{{7}{4}{figure.caption.7}}}
\newlabel{fig:failure_modes}{{4}{7}{\textbf {Per-object failure-mode decomposition during online distillation ablations.} We illustrate four task-specific failure modes in simulation (harmful collision, object escape, palm flipped, and hand too far) and report the aggregate unsafe rate together with its per-mode breakdown over training iterations. Results are shown for two objects (\texttt {windcart} and \texttt {cow}); lower is better in all plots. Curves correspond to the three compared distillation variants (blue: vanilla DAgger\cite {ross2011reduction}, yellow: vanilla SafeDAgger\cite {zhang2016query}, green: our pipeline)}{figure.caption.7}{}}
